-- SCHEMA FOR COLOMBIA EPIDEMIOLOGICAL DASHBOARD
-- Supabase PostgreSQL + REST API
-- ============================================================

CREATE TABLE IF NOT EXISTS public.casos_individuales (
    id BIGSERIAL PRIMARY KEY,
    "CONSECUTIVE" TEXT,
    "COD_EVE" INTEGER,
    "Nombre_evento" TEXT,
    "FEC_NOT" TIMESTAMP,
    "SEMANA" INTEGER,
    "ANO" INTEGER,
    "INI_SIN" TIMESTAMP,
    "EDAD" INTEGER,
    "UNI_MED" INTEGER,
    "SEXO" TEXT,
    estrato INTEGER,
    "TIP_SS" TEXT,
    "TIP_CAS" INTEGER,
    "PAC_HOS" INTEGER,
    "CON_FIN" INTEGER,
    "GP_GESTAN" INTEGER,
    "AREA" INTEGER,
    "COD_DPTO_O" TEXT,
    "COD_MUN_O" TEXT,
    "Departamento_ocurrencia" TEXT,
    "Municipio_ocurrencia" TEXT,
    "Departamento_residencia" TEXT,
    "Municipio_residencia" TEXT,
    nom_est_f_caso TEXT,
    confirmados INTEGER,
    enfermedad TEXT,
    source_name TEXT,
    source_file TEXT,
    edad_anos NUMERIC,
    grupo_etario TEXT,
    tipo_caso TEXT,
    condicion_final TEXT,
    hospitalizado TEXT,
    area_residencia TEXT,
    unidad_edad TEXT,
    regimen_salud TEXT,
    dias_notificacion NUMERIC
);

CREATE TABLE IF NOT EXISTS public.casos_agregados (
    id BIGSERIAL PRIMARY KEY,
    enfermedad TEXT,
    "año" INTEGER,
    "SEMANA" INTEGER,
    departamento TEXT,
    total_casos BIGINT,
    confirmados BIGINT,
    hospitalizados BIGINT,
    fallecidos BIGINT,
    edad_promedio NUMERIC,
    pct_femenino NUMERIC,
    cod_dpto TEXT,
    month INTEGER,
    risk_label TEXT
);

CREATE TABLE IF NOT EXISTS public.ml_predictions (
    id BIGSERIAL PRIMARY KEY,
    disease TEXT NOT NULL,
    month INTEGER NOT NULL,
    department TEXT NOT NULL,
    city TEXT NOT NULL,
    estimated_cases INTEGER NOT NULL,
    estimated_outbreak_proxy INTEGER NOT NULL,
    outbreak_level TEXT NOT NULL,
    model_used TEXT,
    thermal_floor TEXT,
    avg_temp_c NUMERIC,
    precipitation_mm NUMERIC,
    humidity_pct NUMERIC,
    tropical_score NUMERIC,
    climate_risk_score NUMERIC,
    is_rainy_season INTEGER,
    is_vector_favorable TEXT,
    cases_previous_month NUMERIC,
    cases_previous_2_month_mean NUMERIC,
    cases_previous_3_month_mean NUMERIC,
    validation_r2 NUMERIC,
    validation_mae NUMERIC,
    validation_wape_pct NUMERIC,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE (disease, month, department, city)
);

CREATE TABLE IF NOT EXISTS public.etl_load_metadata (
    id BIGSERIAL PRIMARY KEY,
    loaded_at TIMESTAMPTZ DEFAULT NOW(),
    source TEXT NOT NULL,
    clean_rows BIGINT,
    aggregated_rows BIGINT,
    prediction_rows BIGINT
);

